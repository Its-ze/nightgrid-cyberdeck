{
  "name": "nightgrid-cyberdeck",
  "version": "0.1.0",
  "description": "NightGrid Cyberdeck is a dark cross-platform USB field deck for Heltec V3, GPS modules, Raspberry Pi Picos, and serial consoles.",
  "author": "Its-ze",
  "license": "MIT",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.node.json",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb",
    "dist:win": "npm run build && electron-builder --win nsis",
    "rebuild:native": "electron-builder install-app-deps"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "digital.itsolutions.nightgrid",
    "productName": "NightGrid Cyberdeck",
    "copyright": "Copyright (c) 2026 Its-ze",
    "directories": {
      "output": "release-builds"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@serialport/**/*",
      "node_modules/serialport/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "executableName": "nightgrid-cyberdeck",
      "artifactName": "NightGrid-Cyberdeck-Linux-x64.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "NightGrid-Cyberdeck-Windows-x64-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
